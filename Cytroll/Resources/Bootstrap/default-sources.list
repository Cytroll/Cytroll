# Cytroll default APT sources (Procursus rootless)
# {SUITE} is replaced at install time with the Procursus suite number
# (1800 for iOS 15, 1900 for iOS 16+) — matches BootstrapVersion.aptSuite.
#
# Website vs APT URL notes:
#   Procursus site: https://procursus.com  → APT: https://apt.procurs.us/
#   Chariz site:    https://chariz.com     → APT: https://repo.chariz.com/
#   Havoc:          https://havoc.app/
#   ElleKit:        https://ellekit.space/

# Procursus — core Unix tools / libraries every rootless package depends on.
deb https://apt.procurs.us/ {SUITE} main

# ElleKit — tweak injection library/loader (provides mobilesubstrate).
# Procursus deliberately excludes hooking platforms from its own repo.
# Flat repo (no dists/ hierarchy).
deb https://ellekit.space/ ./

# Havoc — large modern tweak/theme marketplace (free + paid).
deb https://havoc.app/ ./

# Chariz — trusted official marketplace with rootless-ready tweaks.
deb https://repo.chariz.com/ ./
